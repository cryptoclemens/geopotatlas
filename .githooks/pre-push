#!/bin/bash
# Auto-bump patch version on push (nur wenn gh-pages-Struktur vorhanden)

# Nicht bumpen wenn direkt auf gh-pages gepusht wird (Version bereits aktuell)
while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -q "gh-pages"; then
    exit 0
  fi
done

if [ ! -f "index.html" ] || [ ! -d "assets" ]; then
  exit 0
fi

BUNDLE=$(ls assets/*.js 2>/dev/null | head -1)
if [ -z "$BUNDLE" ]; then
  exit 0
fi

# Aktuelle Version aus index.html lesen
CURRENT=$(grep -o 'v[0-9]\+\.[0-9]\+\.[0-9]\+' index.html | head -1)
if [ -z "$CURRENT" ]; then
  exit 0
fi

# Patch-Version hochzählen
MAJOR=$(echo "$CURRENT" | sed 's/v\([0-9]*\)\..*/\1/')
MINOR=$(echo "$CURRENT" | sed 's/v[0-9]*\.\([0-9]*\)\..*/\1/')
PATCH=$(echo "$CURRENT" | sed 's/.*\.\([0-9]*\)$/\1/')
NEW="v${MAJOR}.${MINOR}.$((PATCH + 1))"

# index.html aktualisieren
sed -i "s/${CURRENT}/${NEW}/g" index.html

# Bundle-Versionskonstante aktualisieren (const kv="vX.Y.Z")
sed -i "s/const kv=\"${CURRENT}\"/const kv=\"${NEW}\"/" "$BUNDLE"

# Committen
git add index.html "$BUNDLE"
git commit -m "deploy: ${NEW} (auto version bump)"

echo "🔢 Version: ${CURRENT} → ${NEW}"
